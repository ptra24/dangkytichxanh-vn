{
  "openapi": "3.0.0",
  "info": {
    "title": "AZ Media - Đăng Ký Tích Xanh VN - API Documentation",
    "description": "Tài liệu đặc tả toàn bộ các APIs Backend phục vụ việc đăng ký tư vấn dịch vụ tích xanh và hệ thống hiển thị bài viết tin tức (Blog) của dự án dangkytichxanh.vn, được vận hành và tối ưu bởi AZ Media.",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "http://127.0.0.1:8000",
      "description": "Laravel Local Development Server"
    }
  ],
  "paths": {
    "/api/contact": {
      "post": {
        "summary": "Đăng ký tư vấn dịch vụ tích xanh",
        "description": "Nhận thông tin đăng ký tư vấn của khách hàng từ Form Frontend, kiểm tra tính hợp lệ của dữ liệu, lưu vào cơ sở dữ liệu và kích hoạt thông báo email.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": [
                  "name",
                  "phone",
                  "link",
                  "service"
                ],
                "properties": {
                  "name": {
                    "type": "string",
                    "description": "Họ và tên khách hàng gửi yêu cầu",
                    "example": "Nguyễn Văn A"
                  },
                  "phone": {
                    "type": "string",
                    "description": "Số điện thoại Zalo liên hệ của khách hàng",
                    "example": "0912345678"
                  },
                  "link": {
                    "type": "string",
                    "description": "Đường dẫn trang cá nhân hoặc Fanpage cần đăng ký tích xanh",
                    "example": "https://facebook.com/koolguy"
                  },
                  "service": {
                    "type": "string",
                    "description": "Loại dịch vụ tích xanh khách hàng chọn (Facebook, TikTok, v.v.)",
                    "example": "Tích Xanh Facebook"
                  },
                  "email": {
                    "type": "string",
                    "format": "email",
                    "description": "Địa chỉ email của khách hàng (Tùy chọn)",
                    "example": "customer@example.com"
                  },
                  "message": {
                    "type": "string",
                    "description": "Lời nhắn hoặc yêu cầu chi tiết thêm (Tùy chọn)",
                    "example": "Cần hỗ trợ lên tích xanh Fanpage doanh nghiệp nhanh trong ngày."
                  }
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Đăng ký thành công và đã lưu thông tin vào CSDL",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "message": {
                      "type": "string",
                      "example": "Đăng ký tư vấn tích xanh thành công! Chúng tôi sẽ liên hệ với bạn trong giây lát."
                    },
                    "data": {
                      "type": "object",
                      "properties": {
                        "id": {
                          "type": "integer",
                          "example": 1
                        },
                        "name": {
                          "type": "string",
                          "example": "Nguyễn Văn A"
                        },
                        "phone": {
                          "type": "string",
                          "example": "0912345678"
                        },
                        "link": {
                          "type": "string",
                          "example": "https://facebook.com/koolguy"
                        },
                        "service": {
                          "type": "string",
                          "example": "Tích Xanh Facebook"
                        },
                        "status": {
                          "type": "string",
                          "example": "pending"
                        },
                        "created_at": {
                          "type": "string",
                          "format": "date-time",
                          "example": "2026-05-26T04:07:28.000000Z"
                        }
                      }
                    }
                  }
                }
              }
            }
          },
          "422": {
            "description": "Dữ liệu gửi lên không hợp lệ (Lỗi Validation)",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": false
                    },
                    "message": {
                      "type": "string",
                      "example": "Dữ liệu gửi lên không hợp lệ."
                    },
                    "errors": {
                      "type": "object",
                      "properties": {
                        "name": {
                          "type": "array",
                          "items": {
                            "type": "string",
                            "example": "Vui lòng nhập họ và tên."
                          }
                        },
                        "phone": {
                          "type": "array",
                          "items": {
                            "type": "string",
                            "example": "Vui lòng nhập số điện thoại."
                          }
                        },
                        "link": {
                          "type": "array",
                          "items": {
                            "type": "string",
                            "example": "Vui lòng nhập link tài khoản / Fanpage."
                          }
                        }
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/blog": {
      "get": {
        "summary": "Lấy danh sách tất cả bài viết của Blog",
        "description": "Lấy ra danh sách các bài viết tin tức và cẩm nang lên tích xanh mới nhất, hỗ trợ hiển thị danh mục bài viết ở trang chủ.",
        "responses": {
          "200": {
            "description": "Danh sách các bài viết lấy ra thành công",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "data": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/BlogPost"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/api/blog/{slug}": {
      "get": {
        "summary": "Xem chi tiết bài viết qua Slug",
        "description": "Lấy thông tin nội dung chi tiết của một bài viết cụ thể dựa trên đường dẫn tĩnh (Slug) thân thiện với SEO.",
        "parameters": [
          {
            "name": "slug",
            "in": "path",
            "required": true,
            "description": "Slug thân thiện SEO của bài viết cần xem chi tiết",
            "schema": {
              "type": "string"
            },
            "example": "cach-dang-ky-tich-xanh-facebook-nhanh-nhat-nam-2026"
          }
        ],
        "responses": {
          "200": {
            "description": "Lấy chi tiết bài viết thành công",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": true
                    },
                    "data": {
                      "$ref": "#/components/schemas/BlogPost"
                    }
                  }
                }
              }
            }
          },
          "404": {
            "description": "Không tìm thấy bài viết ứng với slug được cung cấp",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "success": {
                      "type": "boolean",
                      "example": false
                    },
                    "message": {
                      "type": "string",
                      "example": "Không tìm thấy bài viết."
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "BlogPost": {
        "type": "object",
        "properties": {
          "id": {
            "type": "integer",
            "example": 1
          },
          "title": {
            "type": "string",
            "example": "Cách đăng ký Tích Xanh Facebook nhanh nhất năm 2026"
          },
          "slug": {
            "type": "string",
            "example": "cach-dang-ky-tich-xanh-facebook-nhanh-nhat-nam-2026"
          },
          "content": {
            "type": "string",
            "example": "Quy trình đăng ký tích xanh thông qua Meta Verified chi tiết từ A-Z..."
          },
          "excerpt": {
            "type": "string",
            "example": "Hướng dẫn từng bước đăng ký tích xanh nhanh chóng nhất..."
          },
          "image_url": {
            "type": "string",
            "example": "https://images.unsplash.com/photo-1611162617213-7d7a39e9b1d7"
          },
          "created_at": {
            "type": "string",
            "format": "date-time",
            "example": "2026-05-26T04:06:53.000000Z"
          },
          "updated_at": {
            "type": "string",
            "format": "date-time",
            "example": "2026-05-26T04:06:53.000000Z"
          }
        }
      }
    }
  }
}
